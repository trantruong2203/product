{
  "name": "geo-saas-backend",
  "version": "1.0.0",
  "description": "GEO SaaS Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/node": "^7.120.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.28.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.1",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.27.0",
    "pg": "^8.20.0",
    "prom-client": "^15.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
