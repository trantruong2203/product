# Docker Environment Configuration
NODE_ENV=production

# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/geo_saas

# JWT Configuration (REQUIRED - minimum 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-12345

# JWT expiration
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://redis:6379

# Frontend URL
FRONTEND_URL=http://localhost

# Optional: AI API Keys (leave empty if not needed)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=

# Optional: CAPTCHA
RECAPTCHA_API_KEY=

# Optional: Monitoring
SENTRY_DSN=

# Playwright
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_SCREENSHOTS_PATH=./screenshots
