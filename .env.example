# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string (required)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/geo_saas

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT secret key for token signing (REQUIRED - minimum 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-strong-secret-key-min-32-characters-long

# JWT token expiration time
JWT_EXPIRES_IN=7d

# ============================================================================
# CACHE & QUEUE
# ============================================================================
# Redis connection string for caching and job queues
REDIS_URL=redis://localhost:6379

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Backend API port
PORT=3000

# Node environment (development, staging, production)
NODE_ENV=development

# Frontend URL for CORS and redirects
FRONTEND_URL=http://localhost:5173

# ============================================================================
# OPTIONAL: AI API KEYS
# ============================================================================
# OpenAI API key (optional, for ChatGPT integration)
OPENAI_API_KEY=sk-...

# Anthropic API key (optional, for Claude integration)
ANTHROPIC_API_KEY=sk-ant-...

# Google API key (optional, for Gemini integration)
GOOGLE_API_KEY=AIza...

# XAI API key (optional, for Grok integration)
XAI_API_KEY=xai-...

# ============================================================================
# OPTIONAL: CAPTCHA & SECURITY
# ============================================================================
# reCAPTCHA API key for automatic CAPTCHA solving
RECAPTCHA_API_KEY=

# ============================================================================
# OPTIONAL: MONITORING & ERROR TRACKING
# ============================================================================
# Sentry DSN for error tracking and monitoring
SENTRY_DSN=

# ============================================================================
# OPTIONAL: PLAYWRIGHT CONFIGURATION
# ============================================================================
# Playwright browsers path (Docker-specific, leave empty for local development)
PLAYWRIGHT_BROWSERS_PATH=

# Screenshots output directory
PLAYWRIGHT_SCREENSHOTS_PATH=./screenshots

# ============================================================================
# OPTIONAL: LOGGING & DEBUGGING
# ============================================================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable debug mode for verbose logging
DEBUG=false
