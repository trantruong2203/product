# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/geo_saas

# JWT Configuration
JWT_SECRET=your-strong-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Backend Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# AI API Keys (optional for local development)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
XAI_API_KEY=xai-...

# CAPTCHA Solving (optional)
RECAPTCHA_API_KEY=

# Playwright (Docker-specific, leave empty for local development)
PLAYWRIGHT_BROWSERS_PATH=
PLAYWRIGHT_SCREENSHOTS_PATH=./screenshots
