# Worker Environment Variables

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis
REDIS_URL=redis://localhost:6379

# Gemini Login Credentials (for auto-login script)
GEMINI_EMAIL=your-email@gmail.com
GEMINI_PASSWORD=your-password

# ChatGPT Login Credentials (for auto-login script)
CHATGPT_EMAIL=your-email@email.com
CHATGPT_PASSWORD=your-password

# Claude Login Credentials (for auto-login script)
CLAUDE_EMAIL=your-email@email.com
CLAUDE_PASSWORD=your-password

# Worker Settings
WORKER_CONCURRENCY=1
MAX_BROWSER_CONTEXTS=1
MEMORY_THRESHOLD_MB=1200
HEALTH_PORT=8080

# Optional: 2Captcha API for auto-solving CAPTCHAs
# RECAPTCHA_API_KEY=your-2captcha-api-key
