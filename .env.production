# Production Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=generate-a-random-secret-here
JWT_EXPIRES_IN=7d

# Frontend URL (for production)
FRONTEND_URL=https://your-domain.com
VITE_API_URL=https://your-api-domain.com

# ====================
# AI Engine Login Credentials
# ====================

# Gemini
GEMINI_EMAIL=your-gemini-email@gmail.com
GEMINI_PASSWORD=your-gemini-password

# ChatGPT
CHATGPT_EMAIL=your-chatgpt-email@email.com
CHATGPT_PASSWORD=your-chatgpt-password

# Claude
CLAUDE_EMAIL=your-claude-email@email.com
CLAUDE_PASSWORD=your-claude-password

# ====================
# Optional
# ====================

# 2Captcha API for auto-solving CAPTCHAs
# RECAPTCHA_API_KEY=your-2captcha-api-key

# Worker Settings
WORKER_CONCURRENCY=1
MAX_BROWSER_CONTEXTS=1
MEMORY_THRESHOLD_MB=1200
HEALTH_PORT=8080
